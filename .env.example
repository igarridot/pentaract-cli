PENTARACT_BASE_URL=http://host.docker.internal:8080
PENTARACT_EMAIL=user@example.com
PENTARACT_PASSWORD=change-me
PENTARACT_STORAGE=
PENTARACT_SOURCE_DIR=/source
PENTARACT_RETRIES=3
PENTARACT_RETRY_DELAY=2s

# Telegram notifications (optional)
# Both variables must be set to enable notifications.
# TELEGRAM_BOT_TOKEN: token provided by @BotFather, format: {bot_id}:{hash}
# TELEGRAM_CHAT_ID:   exact chat ID from Telegram (positive for DMs, negative for groups/channels)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
